MOODLE_DOCKER_WWWROOT=/var/www/html
MOODLE_DOCKER_PHP_VERSION=8.2
MOODLE_DOCKER_BROWSER=firefox
MOODLE_DOCKER_DB_VERSION=mysql:8.0

MOODLE_DATA=/var/www/moodledata
MOODLE_ADMIN=admin
MOODLE_URL=https://develop.ivana.academy


# Database configuration - Equal values in db.env
MOODLE_DBTYPE=mariadb
MOODLE_DBLIB=native
MOODLE_DBHOST=db
MOODLE_DBNAME=moodle
MOODLE_DBPFX=mdl_
MOODLE_DBCOLLATION=utf8mb4_bin


# =============================================================================
# PRODUCTION — Sobrescreve defaults.env
# =============================================================================

# Production URL
MOODLE_URL=https://ivana.academy

# Debug DESABILITADO em prod
MOODLE_DEBUG=MINIMAL
MOODLE_DEBUG_DISPLAY=0

# Performance (opcache sem invalidação)
PHP_OPCACHE_VALIDATE_TIMESTAMPS=0

# Logging (apenas warnings e erros)
LOG_LEVEL=warning

# Portas padrão HTTP/HTTPS
MOODLE_HTTP_PORT=80
MOODLE_HTTPS_PORT=443

# Database (NÃO expor porta em prod)
# DB_PORT comentado = porta não será exposta no host
# DB_PORT=3306