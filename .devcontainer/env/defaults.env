
# =============================================================================
# DEFAULTS — Valores compartilhados entre dev e prod (não-sensíveis)
# Sobrescrito por development.env ou production.env
# =============================================================================

MOODLE_DOCKER_PHP_VERSION=8.1
MOODLE_DOCKER_BROWSER=firefox
MOODLE_DOCKER_DB_VERSION=mysql:8.0

# Database Configuration
MOODLE_DBTYPE=mysqli
MOODLE_DBLIB=native
MOODLE_DBHOST=db
MOODLE_DBNAME=moodle
MOODLE_DBPFX=mdl_
MOODLE_DBCOLL=utf8mb4_bin

# Moodle Paths
MOODLE_DATA=/var/www/moodledata
MOODLE_DOCKER_WWWROOT=/var/www/html

# Admin
MOODLE_ADMIN=admin

# Apache
APACHE_RUN_USER=www-data
APACHE_RUN_GROUP=www-data

# Timezone
TZ=America/Sao_Paulo

# PHP Settings
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=300
PHP_POST_MAX_SIZE=100M
PHP_UPLOAD_MAX_FILESIZE=100M