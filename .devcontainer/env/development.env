MOODLE_DOCKER_WWWROOT=/var/www/html
MOODLE_DOCKER_PHP_VERSION=8.2
MOODLE_DOCKER_BROWSER=firefox
MOODLE_DOCKER_DB_VERSION=mysql:8.0

MOODLE_DATA=/var/www/moodledata
MOODLE_ADMIN=admin


# Database configuration - Equal values in db.env
MOODLE_DBTYPE=mariadb
MOODLE_DBLIB=native
MOODLE_DBHOST=db
MOODLE_DBNAME=moodle
MOODLE_DBPFX=mdl_
MOODLE_DBCOLLATION=utf8mb4_bin


# =============================================================================
# DEVELOPMENT — Sobrescreve defaults.env
# =============================================================================

# Development URL
MOODLE_URL=https://develop.ivana.academy

# Debug Mode (DEVELOPER mostra todos os erros)
MOODLE_DEBUG=DEVELOPER
MOODLE_DEBUG_DISPLAY=1

# Performance (permite invalidação de cache para hot-reload)
PHP_OPCACHE_VALIDATE_TIMESTAMPS=1

# Xdebug (se habilitado no Dockerfile)
XDEBUG_MODE=debug
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_CLIENT_PORT=9003

# Logging
LOG_LEVEL=debug

# Portas customizadas (evitar conflito com outras apps)
MOODLE_HTTP_PORT=80
MOODLE_HTTPS_PORT=443
DB_PORT=3306